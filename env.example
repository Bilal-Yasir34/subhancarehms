# Subhan Care Clinic — environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# Supabase project URL (find in Supabase dashboard > Project Settings > API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/publishable key (safe for client-side use ONLY because
# Row Level Security is enabled on every table in this project).
# Do NOT put the service_role/secret key here or anywhere in this repo.
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
